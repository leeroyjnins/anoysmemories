# Copy this file to .env and fill in your Supabase values
# Find these in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Edge Functions (Cloudflare Stream)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Donation link shown on the QR page (leave blank to hide the section)
VITE_DONATION_URL=https://your-donation-link-here
